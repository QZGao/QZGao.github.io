{
  "name": "qzgao-homepage",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "check": "astro check",
    "preview": "astro preview",
    "test": "vitest run",
    "check:links": "node scripts/check-links.mjs",
    "check:worker": "wrangler deploy --dry-run --config workers/qqmusic-api/wrangler.toml",
    "verify": "npm test && npm run build && npm run check:links && npm run check:worker"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "5.2.8",
    "@fontsource-variable/source-serif-4": "5.2.9",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "astro": "7.0.7",
    "pica": "10.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/sitemap": "3.7.3",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
