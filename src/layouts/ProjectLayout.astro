---
import type { CollectionEntry } from 'astro:content';
import SiteLayout from './SiteLayout.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  tool?: boolean;
}

const { project, tool = false } = Astro.props;
const { data } = project;
---

<SiteLayout title={data.title} description={data.summary} pageClass={tool ? 'tool-page' : ''}>
  <div class="shell">
    <header class="project-intro">
      <div class="project-intro__rail">
        <a class="back-link" href="/projects/">← Projects</a>
        <dl>
          <div>
            <dt>Type</dt>
            <dd>{data.kind}</dd>
          </div>
          <div>
            <dt>Status</dt>
            <dd>{data.status}</dd>
          </div>
          <div>
            <dt>Year</dt>
            <dd>{data.year}</dd>
          </div>
        </dl>
      </div>

      <div class="project-intro__body">
        <p class="eyebrow">Project / {project.id.replaceAll('-', ' ')}</p>
        <h1>{data.title}</h1>
        <p class="lede">{data.summary}</p>

        {data.tags.length > 0 && (
          <ul class="tag-list">
            {data.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        )}

        {data.links.length > 0 && (
          <div class="cluster no-print">
            {data.links.map((link) => (
              <a class="text-link" href={link.url}>{link.label}</a>
            ))}
          </div>
        )}
      </div>
    </header>

    <section class:list={['project-content', { 'project-content--tool': tool }]}>
      <slot />
    </section>
  </div>
</SiteLayout>

<style>
  .project-intro {
    display: grid;
    grid-template-columns: minmax(11rem, 0.8fr) minmax(0, 2.2fr);
    gap: var(--space-5);
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--rule-strong);
  }

  .project-intro__rail {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .back-link {
    width: fit-content;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 620;
  }

  dl {
    display: grid;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--step--1);
  }

  dl div {
    display: grid;
    grid-template-columns: 3.6rem 1fr;
    gap: var(--space-2);
    padding-top: var(--space-1);
    border-top: 1px solid var(--rule);
  }

  dt {
    color: var(--ink-faint);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
  }

  dd {
    text-transform: capitalize;
  }

  .project-intro__body {
    max-width: 54rem;
  }

  .project-intro__body > * + * {
    margin-top: var(--space-4);
  }

  .project-content {
    padding-block: var(--space-6);
  }

  .project-content:not(.project-content--tool) {
    display: grid;
    grid-template-columns: minmax(11rem, 0.8fr) minmax(0, 2.2fr);
    gap: var(--space-5);
  }

  .project-content:not(.project-content--tool)::before {
    color: var(--ink-soft);
    content: 'Project note';
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  @media (max-width: 46rem) {
    .project-intro,
    .project-content:not(.project-content--tool) {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .project-intro__rail {
      gap: var(--space-4);
    }

    dl {
      grid-template-columns: repeat(3, 1fr);
    }

    dl div {
      display: block;
    }

    .project-content:not(.project-content--tool)::before {
      margin-bottom: calc(-1 * var(--space-2));
    }
  }
</style>
