---
import type { CollectionEntry } from 'astro:content';
import InlineMarkdown from '../components/InlineMarkdown.astro';
import SiteLayout from './SiteLayout.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  tool?: boolean;
}

const { project, tool = false } = Astro.props;
const { data } = project;
---

<SiteLayout title={data.title} description={data.summary}>
  <div class="shell">
    <header class="project-intro">
      <a class="back-link" href="/projects/">
        <span aria-hidden="true">←</span>
        <span>Projects</span>
      </a>
      <h1>{data.title}</h1>
      <p class="lede">{data.summary}</p>
      <p class="project-meta">
        <InlineMarkdown content={data.year} />
        {data.archived && ' · Archived'}
      </p>

      {data.links.length > 0 && (
        <div class="cluster no-print">
          {data.links.map((link) => <a class="text-link" href={link.url}>{link.label}</a>)}
        </div>
      )}
    </header>

    <section class:list={['project-content', { 'project-content--tool': tool }]}>
      <slot />
    </section>
  </div>
</SiteLayout>

<style>
  .project-intro {
    max-width: 48rem;
    padding-block: var(--space-6) var(--space-5);
    border-bottom: 1px solid var(--rule);
  }

  .project-intro > * + * {
    margin-top: var(--space-3);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
    font-size: var(--step-0);
    font-weight: 600;
  }

  .project-meta {
    color: var(--ink-faint);
    font-size: var(--step--1);
  }

  .project-content {
    max-width: var(--measure);
    padding-block: var(--space-5) var(--space-7);
  }

  .project-content--tool {
    max-width: none;
  }
</style>
