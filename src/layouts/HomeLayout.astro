---
import SiteLayout from './SiteLayout.astro';
---

<SiteLayout>
  <article class="shell home prose">
    <slot />
  </article>
</SiteLayout>

<style>
  .home {
    max-width: 48rem;
    padding-block: var(--space-7);
  }

  .home :global(h1 + p) {
    max-width: 60ch;
    margin-top: var(--space-3);
    color: var(--ink-soft);
    font-size: var(--step-1);
    line-height: 1.6;
  }
</style>
