---
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<ul class="project-list">
  {projects.map((project) => {
    const href = project.data.route ?? `/projects/${project.id}/`;
    return (
      <li class="project-row">
        <a href={href}>
          <span class="project-row__heading">
            <strong>{project.data.title}</strong>
            <span class="project-row__year">{project.data.year}</span>
          </span>
          <span class="project-row__summary">{project.data.summary}</span>
          {project.data.status === 'archived' && (
            <span class="project-row__status">Archived</span>
          )}
        </a>
      </li>
    );
  })}
</ul>

<style>
  .project-list {
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--rule);
    list-style: none;
  }

  .project-row {
    border-bottom: 1px solid var(--rule);
  }

  .project-row a {
    display: grid;
    gap: var(--space-1);
    padding-block: var(--space-3);
    color: var(--ink);
    text-decoration: none;
  }

  .project-row a:hover strong {
    color: var(--accent);
  }

  .project-row__heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .project-row__heading strong {
    font-size: var(--step-1);
    font-weight: 650;
  }

  .project-row__year,
  .project-row__status {
    color: var(--ink-faint);
    font-size: var(--step--1);
  }

  .project-row__summary {
    max-width: var(--measure);
    color: var(--ink-soft);
  }

  .project-row__status {
    width: fit-content;
  }
</style>
