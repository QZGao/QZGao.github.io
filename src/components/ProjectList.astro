---
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<ol class="project-list">
  {projects.map((project, index) => {
    const href = project.data.route ?? `/projects/${project.id}/`;
    return (
      <li class="project-row">
        <a href={href}>
          <span class="project-row__number" aria-hidden="true">
            {String(index + 1).padStart(2, '0')}
          </span>
          <span class="project-row__content">
            <span class="project-row__heading">
              <strong>{project.data.title}</strong>
              <span>{project.data.year}</span>
            </span>
            <span class="project-row__summary">{project.data.summary}</span>
            <span class="project-row__meta">
              {project.data.kind} · {project.data.status}
            </span>
          </span>
          <span class="project-row__arrow" aria-hidden="true">→</span>
        </a>
      </li>
    );
  })}
</ol>

<style>
  .project-list {
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--rule-strong);
    list-style: none;
  }

  .project-row {
    border-bottom: 1px solid var(--rule);
  }

  .project-row a {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr) auto;
    gap: var(--space-3);
    padding-block: var(--space-4);
    color: var(--ink);
    text-decoration: none;
  }

  .project-row a:hover strong,
  .project-row a:hover .project-row__arrow {
    color: var(--accent);
  }

  .project-row__number,
  .project-row__meta,
  .project-row__heading > span {
    color: var(--ink-faint);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .project-row__content {
    display: grid;
    gap: var(--space-1);
  }

  .project-row__heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .project-row__heading strong {
    font-family: var(--font-sans);
    font-size: var(--step-1);
    font-weight: 610;
    line-height: 1.25;
    transition: color var(--transition);
  }

  .project-row__summary {
    max-width: 48rem;
    color: var(--ink-soft);
  }

  .project-row__arrow {
    align-self: center;
    font-family: var(--font-mono);
    transition:
      color var(--transition),
      transform var(--transition);
  }

  .project-row a:hover .project-row__arrow {
    transform: translateX(0.2rem);
  }

  @media (max-width: 34rem) {
    .project-row a {
      grid-template-columns: 1.8rem minmax(0, 1fr);
    }

    .project-row__arrow {
      display: none;
    }

    .project-row__heading {
      display: grid;
      gap: var(--space-1);
    }
  }
</style>
