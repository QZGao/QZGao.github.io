---
import type { CollectionEntry } from 'astro:content';
import InlineMarkdown from './InlineMarkdown.astro';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<ul class="project-list">
  {projects.map((project) => {
    const href = `/projects/${project.id}/`;
    return (
      <li class="project-row">
        <a href={href}>
          <span class="project-row__heading">
            <strong>{project.data.title}</strong>
            <span class="project-row__year"><InlineMarkdown content={project.data.year} /></span>
          </span>
          <span class="project-row__summary">{project.data.summary}</span>
        </a>
      </li>
    );
  })}
</ul>

<style>
  .project-list {
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--rule);
    list-style: none;
  }

  .project-row {
    border-bottom: 1px solid var(--rule);
  }

  .project-list .project-row > a {
    display: block;
    min-width: 0;
    padding-block: var(--space-3);
    color: var(--ink);
    text-decoration: none;
  }

  .project-list .project-row > a:hover strong {
    color: var(--accent);
  }

  .project-row__heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: baseline;
    gap: var(--space-3);
  }

  .project-row__heading strong {
    min-width: 0;
    font-size: var(--step-1);
    font-weight: 650;
    overflow-wrap: anywhere;
  }

  .project-row__year {
    color: var(--ink-faint);
    font-size: var(--step--1);
  }

  .project-row__summary {
    display: block;
    max-width: var(--measure);
    margin-top: var(--space-1);
    color: var(--ink-soft);
  }
</style>
