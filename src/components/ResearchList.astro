---
import type { CollectionEntry } from 'astro:content';
import InlineMarkdown from './InlineMarkdown.astro';

interface Props {
  entries: CollectionEntry<'research'>[];
  headingLevel?: 'h2' | 'h3';
}

const { entries, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
---

<div class="research-list">
  {entries.map((entry) => (
    <article class="research-entry">
      <Heading><a href={`/research/${entry.id}/`}>{entry.data.title}</a></Heading>
      <p><InlineMarkdown content={entry.data.citation} /></p>
    </article>
  ))}
</div>

<style>
  .research-list {
    border-top: 1px solid var(--rule);
  }

  .research-entry {
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--rule);
  }

  .research-entry > * + * {
    margin-top: var(--space-1);
  }

  :is(h2, h3) a {
    color: var(--ink);
    text-decoration: none;
  }

  :is(h2, h3) a:hover {
    color: var(--accent);
  }

  p {
    max-width: var(--measure);
    color: var(--ink-soft);
  }
</style>
