---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'research'>[];
}

const { entries } = Astro.props;
---

<div class="research-list">
  {entries.map((entry, index) => (
    <article class="research-entry">
      <div class="research-entry__meta">
        <span>{String(index + 1).padStart(2, '0')}</span>
        <span>{entry.data.kicker}</span>
      </div>
      <div class="research-entry__body">
        <h3><a href={`/research/${entry.id}/`}>{entry.data.title}</a></h3>
        <p>{entry.data.summary}</p>
        <ul class="tag-list">
          {entry.data.tags.map((tag) => <li>{tag}</li>)}
        </ul>
      </div>
    </article>
  ))}
</div>

<style>
  .research-list {
    border-top: 1px solid var(--rule-strong);
  }

  .research-entry {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: var(--space-4);
    padding-block: var(--space-5);
    border-bottom: 1px solid var(--rule);
  }

  .research-entry__meta {
    display: grid;
    align-content: start;
    gap: var(--space-1);
    color: var(--ink-faint);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .research-entry__body {
    max-width: var(--measure);
  }

  .research-entry__body > * + * {
    margin-top: var(--space-3);
  }

  h3 a {
    color: var(--ink);
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--accent);
  }

  p {
    color: var(--ink-soft);
  }

  @media (max-width: 34rem) {
    .research-entry {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .research-entry__meta {
      grid-template-columns: auto 1fr;
      gap: var(--space-3);
    }
  }
</style>
