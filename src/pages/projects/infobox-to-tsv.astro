---
import { getEntry } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';

const project = await getEntry('projects', 'infobox-to-tsv');
if (!project) throw new Error('Missing project entry: infobox-to-tsv');
---

<ProjectLayout project={project} tool>
  <div class="tool" data-infobox-extractor>
    <p class="tool-note">
      Runs in this browser against a site's public MediaWiki API. Please use it for small datasets, not unattended crawling.
    </p>

    <form class="extractor" data-extractor-form>
      <fieldset class="extractor__section">
        <legend>Source</legend>

        <div class="field">
          <label for="wiki-url">Wiki article-path URL</label>
          <input
            id="wiki-url"
            data-wiki-url
            data-lock-while-running
            name="wiki-url"
            type="url"
            value="https://en.wikipedia.org/wiki/"
            inputmode="url"
            autocomplete="url"
            required
            aria-describedby="wiki-url-hint"
          />
          <p class="field-hint" id="wiki-url-hint">
            For example, <code>https://en.wikipedia.org/wiki/</code>. Only HTTP and HTTPS wikis
            that permit cross-origin API requests can be read.
          </p>
        </div>

        <div class="category-fields">
          <div class="field">
            <label for="category-name">Add pages from a category</label>
            <input
              id="category-name"
              data-category
              data-lock-while-running
              name="category"
              type="text"
              placeholder="Category name"
              autocomplete="off"
            />
          </div>
          <button class="button-secondary" data-load-category type="button">
            Load category
          </button>
        </div>
      </fieldset>

      <fieldset class="extractor__section">
        <legend>Selection</legend>

        <div class="selection-grid">
          <div class="field">
            <label for="page-titles">Page titles</label>
            <textarea
              id="page-titles"
              data-pages
              data-lock-while-running
              name="pages"
              rows="10"
              placeholder="Albert Einstein"
              spellcheck="false"
              required
              aria-describedby="page-titles-hint"></textarea>
            <p class="field-hint" id="page-titles-hint">Enter one exact page title per line.</p>
          </div>

          <div class="field">
            <label for="template-names">Template names</label>
            <textarea
              id="template-names"
              data-templates
              data-lock-while-running
              name="templates"
              rows="10"
              spellcheck="false"
              required
              aria-describedby="template-names-hint">Infobox person</textarea>
            <p class="field-hint" id="template-names-hint">
              Enter one name per line, without braces. Multiple templates receive numbered
              column prefixes.
            </p>
          </div>
        </div>
      </fieldset>

      <section class="run-panel" aria-labelledby="run-heading">
        <div class="run-panel__heading">
          <h2 id="run-heading">Run</h2>
          <div class="actions">
            <button data-run type="submit">Start extraction</button>
            <button class="button-danger" data-cancel type="button" disabled>Stop</button>
          </div>
        </div>

        <div class="progress-block">
          <div class="progress-meta">
            <span>Progress</span>
            <span id="infobox-progress-label" data-progress-label>Ready</span>
          </div>
          <progress data-progress value="0" max="1" aria-labelledby="infobox-progress-label">
            0%
          </progress>
        </div>

        <p class="status" data-status data-state="neutral" role="status" aria-live="polite" aria-atomic="true">
          Ready.
        </p>
      </section>

      <section class="output" aria-labelledby="output-heading">
        <div class="output__heading">
          <h2 id="output-heading">Output</h2>
          <button class="button-secondary" data-download type="button" disabled>
            Download TSV
          </button>
        </div>

        <label class="visually-hidden" for="infobox-result">Extracted TSV data</label>
        <textarea
          id="infobox-result"
          data-result
          rows="16"
          readonly
          spellcheck="false"
          aria-describedby="output-hint"></textarea>
        <p class="field-hint" id="output-hint">
          Tabs inside values become spaces; line breaks are represented as <code>\n</code> so
          that each source page remains one record. Values otherwise remain untrusted raw
          wikitext—including spreadsheet formula-like prefixes—so inspect the file before
          opening it in spreadsheet software.
        </p>
      </section>
    </form>
  </div>
</ProjectLayout>

<script>
  import { mountInfoboxExtractor } from '../../features/infobox-extractor/client';

  const extractor = document.querySelector<HTMLElement>('[data-infobox-extractor]');
  if (extractor) mountInfoboxExtractor(extractor);
</script>

<style>
  .tool {
    max-width: 66rem;
  }

  .tool-note {
    max-width: var(--measure);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--rule-strong);
    color: var(--ink-soft);
    font-size: var(--step--1);
  }

  .extractor__section {
    display: grid;
    gap: var(--space-4);
    min-width: 0;
    margin: 0;
    padding: var(--space-5) 0;
    border: 0;
    border-bottom: 1px solid var(--rule);
  }

  legend {
    padding: 0;
    font-family: var(--font-sans);
    font-size: var(--step-1);
    font-weight: 620;
  }

  .field {
    min-width: 0;
  }

  .field label + :is(input, textarea) {
    margin-top: var(--space-1);
  }

  .category-fields {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: var(--space-3);
    max-width: 48rem;
  }

  .selection-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(14rem, 0.8fr);
    gap: var(--space-4);
  }

  textarea,
  input {
    font-family: var(--font-mono);
    font-size: 0.86rem;
  }

  .selection-grid textarea {
    min-height: 14rem;
  }

  .run-panel,
  .output {
    padding-block: var(--space-5);
  }

  .run-panel {
    border-bottom: 1px solid var(--rule);
  }

  .run-panel__heading,
  .output__heading {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .run-panel__heading h2,
  .output__heading h2 {
    font-size: var(--step-1);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .progress-block {
    margin-top: var(--space-4);
  }

  .progress-meta {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    color: var(--ink-soft);
    font-family: var(--font-sans);
    font-size: var(--step--1);
  }

  progress {
    display: block;
    width: 100%;
    height: 0.45rem;
    margin-top: var(--space-2);
    border: 0;
    border-radius: 0;
    background: var(--paper-deep);
    color: var(--signal);
  }

  progress::-webkit-progress-bar {
    background: var(--paper-deep);
  }

  progress::-webkit-progress-value {
    background: var(--signal);
  }

  progress::-moz-progress-bar {
    background: var(--signal);
  }

  .status {
    margin-top: var(--space-3);
  }

  .output textarea {
    min-height: 22rem;
    margin-top: var(--space-4);
    white-space: pre;
  }

  [data-busy='true'] {
    cursor: progress;
  }

  @media (max-width: 46rem) {
    .selection-grid {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .category-fields {
      grid-template-columns: 1fr;
      align-items: stretch;
    }

    .category-fields button,
    .actions button,
    .output__heading button {
      width: 100%;
    }

    .actions {
      width: 100%;
    }
  }
</style>
