---
import { getEntry, render } from 'astro:content';
import QQMusicTool from '../../features/qqmusic/QQMusicTool.astro';
import ProjectLayout from '../../layouts/ProjectLayout.astro';

const project = await getEntry('projects', 'qqmusic-metadata');

if (!project) {
  throw new Error('Missing projects/qqmusic-metadata content entry.');
}

const { Content } = await render(project);
---

<ProjectLayout project={project} tool>
  <article class="prose project-note">
    <Content />
  </article>
  <QQMusicTool />
</ProjectLayout>

<style>
  .project-note {
    margin-bottom: var(--space-5);
  }
</style>
