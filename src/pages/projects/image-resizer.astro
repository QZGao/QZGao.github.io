---
import { getEntry } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';

const project = await getEntry('projects', 'image-resizer');

if (!project) {
  throw new Error('Missing image-resizer project metadata.');
}

---

<ProjectLayout project={project} tool>
  <div class="resizer" data-image-resizer aria-busy="false">
    <div class="controls">
      <div class="file-field">
        <label for="resizer-file">Source image</label>
        <input
          id="resizer-file"
          data-role="file-input"
          type="file"
          accept="image/*"
          aria-describedby="file-hint"
        />
        <p id="file-hint" class="field-hint">
          Processed locally. Images keep their aspect ratio and are never enlarged.
        </p>
      </div>
      <button type="button" data-action="convert" disabled>Resize image</button>
      <button type="button" class="button-secondary" data-action="download" disabled>
        Download PNG
      </button>
    </div>

    <p
      id="resizer-status"
      class="status tool-status"
      data-role="status"
      data-state="idle"
      role="status"
      aria-atomic="true"
    >
      Select an image to begin.
    </p>

    <div class="previews">
      <figure class="preview-card">
        <figcaption>
          <span>Source</span>
          <span class="preview-card__details" data-role="source-details">No image selected</span>
        </figcaption>
        <div class="preview-stage">
          <p data-role="source-placeholder">Source preview</p>
          <img data-role="source-image" src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=" alt="" hidden />
        </div>
      </figure>

      <figure class="preview-card">
        <figcaption>
          <span>Result</span>
          <span class="preview-card__details" data-role="output-details">Awaiting conversion</span>
        </figcaption>
        <div class="preview-stage">
          <p data-role="output-placeholder">Resized preview</p>
          <img data-role="output-image" src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=" alt="" hidden />
        </div>
      </figure>
    </div>
  </div>
</ProjectLayout>

<script>
  import { initImageResizer } from '../../features/image-resizer/image-resizer';

  const root = document.querySelector<HTMLElement>('[data-image-resizer]');

  if (root) {
    initImageResizer(root);
  }
</script>

<style>
  .resizer {
    display: grid;
    gap: var(--space-4);
  }

  .controls {
    display: grid;
    grid-template-columns: minmax(16rem, 1fr) auto auto;
    align-items: start;
    gap: var(--space-3);
  }

  .file-field input {
    margin-top: var(--space-1);
  }

  .controls > button {
    margin-top: calc(1.4rem + var(--space-1));
  }

  .tool-status {
    padding-block: var(--space-2);
    border-block: 1px solid var(--rule);
  }

  .previews {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
  }

  .preview-card {
    min-width: 0;
    border: 1px solid var(--rule-strong);
    background: var(--paper-light);
  }

  .preview-card figcaption {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-1) var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--rule);
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 620;
  }

  .preview-card__details {
    color: var(--ink-soft);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 400;
  }

  .preview-stage {
    display: grid;
    height: clamp(11rem, 24vw, 16rem);
    overflow: hidden;
    place-items: center;
    background: var(--paper);
  }

  .preview-stage p {
    color: var(--ink-faint);
    font-family: var(--font-sans);
    font-size: var(--step--1);
  }

  .preview-stage img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media (max-width: 58rem) {
    .controls {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .controls > button {
      margin-top: 0;
    }

    .controls > button:last-child {
      grid-column: 2;
    }
  }

  @media (max-width: 46rem) {
    .controls,
    .previews {
      grid-template-columns: 1fr;
    }

    .controls > button:last-child {
      grid-column: auto;
    }

    .controls > button {
      width: 100%;
    }
  }
</style>
