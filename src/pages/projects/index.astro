---
import { getCollection } from 'astro:content';
import ProjectList from '../../components/ProjectList.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<SiteLayout title="Projects" description="Research software and selected open-source tools by Quinn Gao.">
  <div class="shell compact-page">
    <header class="page-intro">
      <div class="page-intro__body">
        <h1>Projects</h1>
        <p class="lede">Research software and selected open-source tools.</p>
      </div>
    </header>

    <div class="projects-index" aria-label="Projects">
      <ProjectList projects={projects} />
    </div>
  </div>
</SiteLayout>

<style>
  .compact-page {
    max-width: 58rem;
  }

  .projects-index {
    padding-bottom: var(--space-7);
  }
</style>
