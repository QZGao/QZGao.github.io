---
import { getCollection } from 'astro:content';
import ProjectList from '../../components/ProjectList.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const projects = (await getCollection(
  'projects',
  ({ data }) => !data.archived,
))
  .sort((a, b) => a.data.order - b.data.order);

const categoryOrder = ['academic', 'toolkit', 'wikipedia'] as const;
const categoryLabels = {
  academic: 'Academic',
  toolkit: 'Toolkit',
  wikipedia: 'Wikipedia',
} as const;

const groups = categoryOrder.map((category) => ({
  category,
  label: categoryLabels[category],
  projects: projects.filter((project) => project.data.category === category),
}));
---

<SiteLayout title="Projects" description="Academic projects, practical tools, and Wikipedia work by Quinn Gao.">
  <div class="shell compact-page">
    <header class="page-intro">
      <div class="page-intro__body">
        <h1>Projects</h1>
        <!-- <p class="lede">Some projects and tools I developed.</p> -->
      </div>
    </header>

    <div class="projects-index" aria-label="Projects">
      {groups.map(({ category, label, projects }) => (
        <section class="project-category" aria-labelledby={`${category}-heading`}>
          <h2 id={`${category}-heading`}>{label}</h2>
          <ProjectList projects={projects} />
        </section>
      ))}
    </div>
  </div>
</SiteLayout>

<style>
  .compact-page {
    max-width: 58rem;
  }

  .projects-index {
    padding-bottom: var(--space-7);
  }

  .project-category + .project-category {
    margin-top: var(--space-6);
  }

  .project-category h2 {
    margin-bottom: var(--space-3);
    font-size: var(--step-1);
  }
</style>
