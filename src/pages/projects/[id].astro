---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';

export async function getStaticPaths() {
  const staticPageIds = new Set(
    Object.keys(import.meta.glob('./*.astro'))
      .map((path) => path.slice(2, -'.astro'.length))
      .filter((id) => id !== 'index' && id !== '[id]'),
  );
  const entries = await getCollection('projects');
  return entries
    .filter((entry) => !staticPageIds.has(entry.id))
    .map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ProjectLayout project={entry}>
  <article class="prose">
    <Content />
  </article>
</ProjectLayout>
