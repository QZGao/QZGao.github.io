---
import InlineMarkdown from '../components/InlineMarkdown.astro';
import { site } from '../data/site';
import SiteLayout from '../layouts/SiteLayout.astro';

interface CvEntry {
  order: number;
  year: string;
  title: string;
  detail: string;
}

const byOrder = (a: CvEntry, b: CvEntry) => a.order - b.order;

const education = ([
  {
    order: 1,
    year: '2024–2026',
    title: 'Northeastern University',
    detail: 'Master of Science, Computer Science',
  },
  {
    order: 2,
    year: '2020–2024',
    title: 'Beijing Normal University',
    detail: 'Bachelor of Science, Physics',
  },
] satisfies CvEntry[]).sort(byOrder);

const experience = ([
  { order: 1, year: '2026–', title: 'Researcher', detail: 'FieldQuantum' },
  { order: 2, year: '2026–', title: 'Software Engineer', detail: 'Hacks/Hackers' },
  { order: 3, year: '2025', title: 'QA & Testing Engineer', detail: 'Evenness' },
] satisfies CvEntry[]).sort(byOrder);
---

<SiteLayout title="Curriculum vitae" description="Curriculum vitae for Quinn Gao, physics researcher and scientific software developer.">
  <div class="shell cv">
    <header class="page-intro">
      <div class="page-intro__body">
        <h1>Qingzheng (Quinn) Gao</h1>
        <nav class="cluster no-print" aria-label="Contact and profiles">
          <a href={`mailto:${site.email}`}>Email</a>
          <a href="https://github.com/QZGao">GitHub</a>
          <a href="https://www.linkedin.com/in/quinn-gao">LinkedIn</a>
        </nav>
      </div>
    </header>

    <section class="cv-section" aria-labelledby="education-heading">
      <h2 id="education-heading">Education</h2>
      <div>
        {education.map((entry) => (
          <article class="cv-entry">
            <p class="cv-entry__date"><InlineMarkdown content={entry.year} /></p>
            <div>
              <h3>{entry.title}</h3>
              <p>{entry.detail}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="cv-section" aria-labelledby="experience-heading">
      <h2 id="experience-heading">Work experience</h2>
      <div>
        {experience.map((entry) => (
          <article class="cv-entry">
            <p class="cv-entry__date"><InlineMarkdown content={entry.year} /></p>
            <div><h3>{entry.title}</h3><p>{entry.detail}</p></div>
          </article>
        ))}
      </div>
    </section>

    <section class="cv-section" aria-labelledby="skills-heading">
      <h2 id="skills-heading">Skills</h2>
      <div class="skill-list">
        <div class="skill-group">
          <h3>Programming Languages</h3>
          <p>Python (PyTorch), C/C++, C# (Unity), Java, JavaScript/TypeScript (Vue, React)</p>
        </div>
        <div class="skill-group">
          <h3>Computing &amp; Infrastructure</h3>
          <p>Linux, Git, Docker, CI/CD, AWS, GCP</p>
        </div>
      </div>
    </section>
  </div>
</SiteLayout>

<style>
  .cv {
    max-width: 58rem;
    padding-bottom: var(--space-7);
  }

  .cv-section {
    display: grid;
    grid-template-columns: 10rem minmax(0, 1fr);
    gap: var(--space-5);
    padding-block: var(--space-5);
    border-top: 1px solid var(--rule);
  }

  .cv-section h2 {
    font-size: var(--step-1);
  }

  .cv-entry {
    display: grid;
    grid-template-columns: 6.5rem minmax(0, 1fr);
    gap: var(--space-3);
    padding-bottom: var(--space-4);
  }

  .cv-entry:last-child {
    padding-bottom: 0;
  }

  .cv-entry__date {
    color: var(--ink-faint);
    font-size: var(--step--1);
  }

  .cv-entry h3 {
    font-size: var(--step-0);
  }

  .cv-entry h3 + p {
    margin-top: var(--space-1);
    color: var(--ink-soft);
  }

  .skill-list {
    display: grid;
    gap: var(--space-4);
  }

  .skill-group h3 {
    font-size: var(--step-0);
  }

  .skill-group p {
    margin-top: var(--space-1);
    color: var(--ink-soft);
  }

  @media (max-width: 40rem) {
    .cv-section {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .cv-entry {
      grid-template-columns: 5.5rem minmax(0, 1fr);
    }
  }
</style>
