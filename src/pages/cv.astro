---
import { site } from '../data/site';
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="Curriculum vitae" description="Curriculum vitae for Quinn Gao, physics researcher and scientific software developer.">
  <div class="shell cv">
    <header class="page-intro">
      <div class="page-intro__body">
        <h1>{site.name}</h1>
        <p class="lede">Physics researcher and former software engineer.</p>
        <nav class="cluster no-print" aria-label="Contact and profiles">
          <a href={`mailto:${site.email}`}>Email</a>
          <a href="https://github.com/QZGao">GitHub</a>
          <a href="https://www.linkedin.com/in/quinn-gao">LinkedIn</a>
        </nav>
      </div>
    </header>

    <section class="cv-section" aria-labelledby="education-heading">
      <h2 id="education-heading">Education</h2>
      <div>
        <article class="cv-entry">
          <p class="cv-entry__date">2024–2026</p>
          <div>
            <h3>Northeastern University</h3>
            <p>Master of Science</p>
          </div>
        </article>
        <article class="cv-entry">
          <p class="cv-entry__date">2020–2024</p>
          <div>
            <h3>Beijing Normal University</h3>
            <p>Bachelor of Science</p>
          </div>
        </article>
      </div>
    </section>

    <section class="cv-section" aria-labelledby="software-heading">
      <h2 id="software-heading">Selected software</h2>
      <div>
        <article class="cv-entry">
          <p class="cv-entry__date">2024–</p>
          <div><h3>spectral_fit</h3><p>Bayesian pulsar radio-spectrum fitting and model comparison.</p></div>
        </article>
        <article class="cv-entry">
          <p class="cv-entry__date">2025–</p>
          <div><h3>CiteForge</h3><p>Reference management tools for Wikimedia editors.</p></div>
        </article>
        <article class="cv-entry">
          <p class="cv-entry__date">2025–</p>
          <div><h3>Cite Unseen</h3><p>Source-type indicators for Wikipedia citations.</p></div>
        </article>
        <article class="cv-entry">
          <p class="cv-entry__date">2025–</p>
          <div><h3>LaTeX Suite</h3><p>A lightweight desktop environment for LaTeX composition.</p></div>
        </article>
      </div>
    </section>
  </div>
</SiteLayout>

<style>
  .cv {
    max-width: 58rem;
    padding-bottom: var(--space-7);
  }

  .cv-section {
    display: grid;
    grid-template-columns: 10rem minmax(0, 1fr);
    gap: var(--space-5);
    padding-block: var(--space-5);
    border-top: 1px solid var(--rule);
  }

  .cv-section h2 {
    font-size: var(--step-1);
  }

  .cv-entry {
    display: grid;
    grid-template-columns: 6.5rem minmax(0, 1fr);
    gap: var(--space-3);
    padding-bottom: var(--space-4);
  }

  .cv-entry:last-child {
    padding-bottom: 0;
  }

  .cv-entry__date {
    color: var(--ink-faint);
    font-size: var(--step--1);
  }

  .cv-entry h3 {
    font-size: var(--step-0);
  }

  .cv-entry h3 + p {
    margin-top: var(--space-1);
    color: var(--ink-soft);
  }

  @media (max-width: 40rem) {
    .cv-section {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .cv-entry {
      grid-template-columns: 5.5rem minmax(0, 1fr);
    }
  }
</style>
