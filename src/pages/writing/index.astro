---
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';

const entries = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<SiteLayout title="Writing" description="Technical notes and personal writing by Quinn Gao.">
  <div class="shell">
    <header class="page-intro">
      <div class="stack--small">
        <p class="eyebrow">Writing</p>
        <p class="folio">Notes outside the formal record</p>
      </div>
      <div class="page-intro__body">
        <h1>Writing</h1>
        <p class="lede">Two notebooks with different temperatures: one for technical work and one for everything that benefits from a little more room.</p>
      </div>
    </header>

    <section class="section section-grid" aria-labelledby="notebooks-heading">
      <p class="section-label">Notebooks</p>
      <div class="writing-list">
        <h2 id="notebooks-heading" class="visually-hidden">Writing notebooks</h2>
        {entries.map((entry, index) => (
          <article>
            <p class="meta">{String(index + 1).padStart(2, '0')} / {entry.data.kind}</p>
            <h2><a href={entry.data.externalUrl}>{entry.data.title}</a></h2>
            <p>{entry.data.summary}</p>
            <a class="text-link" href={entry.data.externalUrl}>Read on Bear Blog</a>
          </article>
        ))}
      </div>
    </section>
  </div>
</SiteLayout>

<style>
  .writing-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--rule-strong);
  }

  article {
    padding: var(--space-5) var(--space-5) var(--space-5) 0;
    border-bottom: 1px solid var(--rule);
  }

  article + article {
    padding-right: 0;
    padding-left: var(--space-5);
    border-left: 1px solid var(--rule);
  }

  article > * + * {
    margin-top: var(--space-3);
  }

  h2 {
    font-size: var(--step-2);
  }

  h2 a {
    color: var(--ink);
    text-decoration: none;
  }

  article p:not(.meta) {
    color: var(--ink-soft);
  }

  @media (max-width: 40rem) {
    .writing-list {
      grid-template-columns: 1fr;
    }

    article,
    article + article {
      padding-inline: 0;
      border-left: 0;
    }
  }
</style>
