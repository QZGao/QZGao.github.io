---
import { site } from '../data/site';
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout>
  <div class="shell home">
    <header class="home-intro">
      <h1>{site.name}</h1>
      <p>
        I am a physics researcher with a background in software engineering. My work focuses on
        machine learning applications in material science and computational physics/biology.
      </p>
    </header>
  </div>
</SiteLayout>

<style>
  .home {
    max-width: 48rem;
  }

  .home-intro {
    padding-block: var(--space-7);
  }

  .home-intro p {
    max-width: 60ch;
    margin-top: var(--space-3);
    color: var(--ink-soft);
    font-size: var(--step-1);
    line-height: 1.6;
  }
</style>
