---
import { getCollection } from 'astro:content';
import ProjectList from '../components/ProjectList.astro';
import ResearchList from '../components/ResearchList.astro';
import { site } from '../data/site';
import SiteLayout from '../layouts/SiteLayout.astro';

const research = (await getCollection('research', ({ data }) => !data.draft && data.featured))
  .sort((a, b) => a.data.order - b.data.order);
const projects = (await getCollection('projects', ({ data }) => !data.draft && data.featured))
  .sort((a, b) => a.data.order - b.data.order);
---

<SiteLayout>
  <div class="shell">
    <section class="home-hero" aria-labelledby="home-title">
      <aside class="home-hero__rail">
        <p class="eyebrow">Physics · computation · open knowledge</p>
        <dl>
          <div>
            <dt>Current</dt>
            <dd>Research at {site.affiliation}</dd>
          </div>
          <div>
            <dt>Practice</dt>
            <dd>Scientific software &amp; open-source tools</dd>
          </div>
          <div>
            <dt>Contact</dt>
            <dd><a href={`mailto:${site.email}`}>{site.email}</a></dd>
          </div>
        </dl>
      </aside>

      <div class="home-hero__body">
        <p class="folio">Quinn Gao / Research notebook</p>
        <h1 id="home-title">Researcher by way of software.</h1>
        <p class="home-hero__statement">
          I work across computational astrophysics, scientific software, and open knowledge—building methods and tools whose assumptions remain visible to the people using them.
        </p>
        <div class="cluster">
          <a class="text-link text-link--internal" href="/research/">Read the research</a>
          <a class="text-link text-link--internal" href="/projects/">Browse the projects</a>
        </div>
      </div>
    </section>

    <section class="section section-grid" aria-labelledby="research-heading">
      <div class="stack--small">
        <p class="section-label">01 / Research</p>
        <a class="text-link text-link--internal" href="/research/">All directions</a>
      </div>
      <div>
        <h2 id="research-heading" class="section-heading">Questions before categories.</h2>
        <p class="section-summary">The work is organised around the inference and infrastructure problems, not around a list of technologies.</p>
        <ResearchList entries={research} />
      </div>
    </section>

    <section class="section section-grid" aria-labelledby="projects-heading">
      <div class="stack--small">
        <p class="section-label">02 / Selected work</p>
        <a class="text-link text-link--internal" href="/projects/">Complete index</a>
      </div>
      <div>
        <h2 id="projects-heading" class="section-heading">Software as an argument.</h2>
        <p class="section-summary">Research packages, open-knowledge infrastructure, and small instruments kept useful enough to remain public.</p>
        <ProjectList projects={projects} />
      </div>
    </section>

    <section class="section section-grid" aria-labelledby="writing-heading">
      <p class="section-label">03 / Marginalia</p>
      <div class="writing-note">
        <h2 id="writing-heading" class="section-heading">Notes beyond the formal record.</h2>
        <p>I keep technical notes about building and learning, alongside a more personal notebook. Both remain intentionally lighter than the research pages here.</p>
        <div class="cluster">
          <a class="text-link" href="https://quinns.bearblog.dev/">Technical notes</a>
          <a class="text-link" href="https://supergrey.bearblog.dev/">Personal notebook</a>
        </div>
      </div>
    </section>
  </div>
</SiteLayout>

<style>
  .home-hero {
    display: grid;
    grid-template-columns: minmax(14rem, 0.8fr) minmax(0, 2.2fr);
    gap: var(--space-6);
    min-height: 38rem;
    padding-block: var(--space-7);
    border-bottom: 1px solid var(--rule-strong);
  }

  .home-hero__rail {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  dl {
    display: grid;
    gap: var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--step--1);
  }

  dl div {
    padding-top: var(--space-2);
    border-top: 1px solid var(--rule);
  }

  dt {
    color: var(--ink-faint);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  dd {
    margin-top: 0.2rem;
  }

  .home-hero__body {
    align-self: center;
    max-width: 58rem;
  }

  .home-hero__body > * + * {
    margin-top: var(--space-4);
  }

  .home-hero__statement {
    max-width: 49rem;
    color: var(--ink-soft);
    font-size: var(--step-2);
    line-height: 1.4;
  }

  .section-heading {
    margin-bottom: var(--space-3);
    font-size: var(--step-2);
  }

  .section-summary {
    max-width: var(--measure);
    margin-bottom: var(--space-5);
    color: var(--ink-soft);
  }

  .writing-note {
    max-width: var(--measure);
  }

  .writing-note > * + * {
    margin-top: var(--space-4);
  }

  @media (max-width: 46rem) {
    .home-hero {
      grid-template-columns: 1fr;
      gap: var(--space-5);
      min-height: auto;
      padding-block: var(--space-6);
    }

    .home-hero__rail {
      gap: var(--space-5);
    }
  }
</style>
