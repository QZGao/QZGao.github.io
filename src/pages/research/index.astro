---
import { getCollection } from 'astro:content';
import ResearchList from '../../components/ResearchList.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const entries = (await getCollection('research', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<SiteLayout title="Research" description="Research in computational astrophysics, Bayesian inference, and citation tools for Wikimedia.">
  <div class="shell compact-page">
    <header class="page-intro">
      <div class="page-intro__body">
        <h1>Research</h1>
        <p class="lede">My work focuses on computational inference in astrophysics and citation tools for Wikimedia.</p>
      </div>
    </header>

    <div class="research-index" aria-label="Research areas">
      <ResearchList entries={entries} headingLevel="h2" />
    </div>
  </div>
</SiteLayout>

<style>
  .compact-page {
    max-width: 58rem;
  }

  .research-index {
    padding-bottom: var(--space-7);
  }
</style>
