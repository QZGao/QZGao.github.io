---
import { getCollection } from 'astro:content';
import ResearchList from '../../components/ResearchList.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const entries = (await getCollection('research'))
  .sort((a, b) => a.data.order - b.data.order);
---

<SiteLayout title="Research" description="Published research by Quinn Gao in computational astrophysics and pulsar radio astronomy.">
  <div class="shell compact-page">
    <header class="page-intro">
      <div class="page-intro__body">
        <h1>Research</h1>
        <!-- <p class="lede">Published work in computational astrophysics and pulsar radio astronomy.</p> -->
      </div>
    </header>

    <div class="research-index" aria-label="Research areas">
      <ResearchList entries={entries} headingLevel="h2" />
    </div>
  </div>
</SiteLayout>

<style>
  .compact-page {
    max-width: 58rem;
  }

  .research-index {
    padding-bottom: var(--space-7);
  }
</style>
