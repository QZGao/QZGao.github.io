<section class="qqmusic-tool" data-qqmusic-tool aria-busy="false" aria-labelledby="qqmusic-tool-heading">
  <div class="tool-heading">
    <div>
      <p class="eyebrow">Metadata workbench</p>
      <h2 id="qqmusic-tool-heading">Catalogue and lyric lookup</h2>
    </div>
    <p>
      Enter a keyword, singer MID, album MID, or song MID, then choose the matching operation.
      Album lookup falls back to the public track-list endpoint when necessary.
    </p>
  </div>

  <div class="query-panel">
    <label for="qqmusic-query">Keyword or QQ Music MID</label>
    <input
      id="qqmusic-query"
      data-input
      type="text"
      autocomplete="off"
      spellcheck="false"
      aria-describedby="qqmusic-query-hint"
      placeholder="For example: 001uz8tl04tdL8"
    />
    <p class="input-hint" id="qqmusic-query-hint">
      Leave this blank only when listing albums to use the default HOYO-MiX singer MID.
    </p>

    <div class="action-grid" role="group" aria-label="QQ Music lookup actions">
      <button type="button" data-action="search">Search by keyword</button>
      <button type="button" data-action="albums">Albums by singer MID</button>
      <button type="button" data-action="album">Album by album MID</button>
      <button type="button" data-action="lyrics">Lyrics by song MID</button>
      <button type="button" data-action="album-lyrics">All lyrics by album MID</button>
      <button type="button" class="button-secondary" data-cancel disabled>Cancel request</button>
    </div>
  </div>

  <div class="request-state">
    <p data-status data-state="idle" role="status" aria-live="polite"></p>
    <div class="progress-row" data-progress-region hidden>
      <progress data-progress max="1" value="0"></progress>
      <span data-progress-text></span>
    </div>
  </div>

  <div class="output-panel">
    <div class="tab-list" role="tablist" aria-label="Output format">
      <button
        id="qqmusic-tab-formatted"
        class="tab-button"
        type="button"
        role="tab"
        aria-selected="true"
        aria-controls="qqmusic-panel-formatted"
      >Formatted</button>
      <button
        id="qqmusic-tab-raw"
        class="tab-button"
        type="button"
        role="tab"
        aria-selected="false"
        aria-controls="qqmusic-panel-raw"
        tabindex="-1"
      >Raw JSON</button>
      <button
        id="qqmusic-tab-tsv"
        class="tab-button"
        type="button"
        role="tab"
        aria-selected="false"
        aria-controls="qqmusic-panel-tsv"
        tabindex="-1"
      >TSV</button>
    </div>

    <div
      id="qqmusic-panel-formatted"
      class="tab-panel"
      role="tabpanel"
      aria-labelledby="qqmusic-tab-formatted"
    >
      <label class="sr-only" for="qqmusic-output-formatted">Formatted output</label>
      <textarea id="qqmusic-output-formatted" data-output="formatted" readonly rows="18"></textarea>
    </div>
    <div
      id="qqmusic-panel-raw"
      class="tab-panel"
      role="tabpanel"
      aria-labelledby="qqmusic-tab-raw"
      hidden
    >
      <label class="sr-only" for="qqmusic-output-raw">Raw JSON output</label>
      <textarea id="qqmusic-output-raw" data-output="raw" readonly rows="18"></textarea>
    </div>
    <div
      id="qqmusic-panel-tsv"
      class="tab-panel"
      role="tabpanel"
      aria-labelledby="qqmusic-tab-tsv"
      hidden
    >
      <label class="sr-only" for="qqmusic-output-tsv">Tab-separated output</label>
      <textarea id="qqmusic-output-tsv" data-output="tsv" readonly rows="18"></textarea>
    </div>
  </div>
</section>

<script>
  import { initializeQQMusicTools } from './controller';

  initializeQQMusicTools();
</script>

