  }

  .tool-heading {
    display: grid;
    grid-template-columns: minmax(14rem, 0.9fr) minmax(0, 1.4fr);
    gap: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--rule);
  }

  .tool-heading h2 {
    margin-top: var(--space-2);
    font-size: var(--step-2);
  }

  .tool-heading > p {
